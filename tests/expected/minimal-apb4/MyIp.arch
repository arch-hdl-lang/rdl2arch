use MyIpPkg;

bus Apb4
  param ADDR_W: const = 3;
  param DATA_W: const = 32;

  psel:    out Bool;
  penable: out Bool;
  pwrite:  out Bool;
  paddr:   out UInt<ADDR_W>;
  pwdata:  out UInt<DATA_W>;
  pstrb:   out UInt<4>;
  pprot:   out UInt<3>;

  pready:  in  Bool;
  prdata:  in  UInt<DATA_W>;
  pslverr: in  Bool;
end bus Apb4

module MyIp
  port clk:      in Clock<SysDomain>;
  port rst:      in Reset<Sync>;
  port s_apb: target Apb4<ADDR_W=3, DATA_W=32>;
  port hwif_in:  in MyIpHwifIn;
  port hwif_out: out MyIpHwifOut;

  default seq on clk rising;

  reg ctrl_r: CtrlReg reset rst => CtrlReg { enable: 0, mode: 0 };
  reg status_r: StatusReg reset rst => StatusReg { status_code: 0 };

  let access: Bool = s_apb.psel and s_apb.penable;
  let wr_fire: Bool = access and s_apb.pwrite;
  let rd_fire: Bool = access and not s_apb.pwrite;

  let rdata_mux: UInt<32> = match s_apb.paddr
    3'h0 => {27'h0, ctrl_r.mode, ctrl_r.enable},
    3'h4 => {24'h0, status_r.status_code},
    _ => 0
  end match;

  seq

    status_r.status_code <= hwif_in.status_status_code;
    if wr_fire
      if s_apb.paddr == 3'h0
        ctrl_r.enable <= s_apb.pwdata[0];
        ctrl_r.mode <= s_apb.pwdata[4:1];
      end if
    end if
  end seq

  comb
    s_apb.pready  = true;
    s_apb.prdata  = rdata_mux;
    s_apb.pslverr = false;

    hwif_out.ctrl_enable = ctrl_r.enable;
    hwif_out.ctrl_mode = ctrl_r.mode;
  end comb

end module MyIp
