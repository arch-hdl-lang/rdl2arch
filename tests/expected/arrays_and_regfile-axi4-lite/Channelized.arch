use ChannelizedPkg;

bus AxiLite
  param ADDR_W: const = 6;
  param DATA_W: const = 32;

  aw_valid: out Bool;
  aw_ready: in  Bool;
  aw_addr:  out UInt<ADDR_W>;
  aw_prot:  out UInt<3>;

  w_valid:  out Bool;
  w_ready:  in  Bool;
  w_data:   out UInt<DATA_W>;
  w_strb:   out UInt<4>;

  b_valid:  in  Bool;
  b_ready:  out Bool;
  b_resp:   in  UInt<2>;

  ar_valid: out Bool;
  ar_ready: in  Bool;
  ar_addr:  out UInt<ADDR_W>;
  ar_prot:  out UInt<3>;

  r_valid:  in  Bool;
  r_ready:  out Bool;
  r_data:   in  UInt<DATA_W>;
  r_resp:   in  UInt<2>;
end bus AxiLite

module Channelized
  port clk:      in Clock<SysDomain>;
  port rst:      in Reset<Sync>;
  port s_axi: target AxiLite<ADDR_W=6, DATA_W=32>;
  port hwif_in:  in ChannelizedHwifIn;
  port hwif_out: out ChannelizedHwifOut;

  default seq on clk rising;

  reg ch_r: Vec<ChReg, 4> reset rst => ChReg { enable: 0, threshold: 0 };
  reg irq_status_r: IrqStatusReg reset rst => IrqStatusReg { pending: 0 };
  reg irq_enable_r: IrqEnableReg reset rst => IrqEnableReg { mask: 0 };

  reg bresp_valid_r: Bool reset rst => false;
  reg rresp_valid_r: Bool reset rst => false;
  reg rdata_r:       UInt<32> reset rst => 0;

  let wr_fire: Bool = s_axi.aw_valid and s_axi.w_valid and not bresp_valid_r;
  let rd_fire: Bool = s_axi.ar_valid and not rresp_valid_r;

  let rdata_mux: UInt<32> = match s_axi.ar_addr
    6'h0 => {16'h0, ch_r[0].threshold, ch_r[0].enable},
    6'h4 => {16'h0, ch_r[1].threshold, ch_r[1].enable},
    6'h8 => {16'h0, ch_r[2].threshold, ch_r[2].enable},
    6'hc => {16'h0, ch_r[3].threshold, ch_r[3].enable},
    6'h20 => {24'h0, irq_status_r.pending},
    6'h24 => {24'h0, irq_enable_r.mask},
    _ => 0
  end match;

  seq
    if bresp_valid_r and s_axi.b_ready
      bresp_valid_r <= false;
    end if
    if wr_fire
      bresp_valid_r <= true;
    end if
    if rresp_valid_r and s_axi.r_ready
      rresp_valid_r <= false;
    end if
    if rd_fire
      rresp_valid_r <= true;
    end if
    if wr_fire
      if s_axi.aw_addr == 6'h20
        irq_status_r.pending <= irq_status_r.pending & (~s_axi.w_data[7:0]);
      end if
      if s_axi.aw_addr == 6'h24
        irq_enable_r.mask <= s_axi.w_data[7:0];
      end if
    end if
    if rd_fire
      rdata_r <= rdata_mux;
    end if
  end seq

  generate_for i in 0..3
    seq
      if wr_fire and s_axi.aw_addr == 6'h0 + i * 4
        ch_r[i].enable <= s_axi.w_data[0];
        ch_r[i].threshold <= s_axi.w_data[15:1];
      end if
    end seq
  end generate_for

  comb
    s_axi.aw_ready = not bresp_valid_r;
    s_axi.w_ready  = not bresp_valid_r;
    s_axi.b_valid  = bresp_valid_r;
    s_axi.b_resp   = 0;

    s_axi.ar_ready = not rresp_valid_r;
    s_axi.r_valid  = rresp_valid_r;
    s_axi.r_data   = rdata_r;
    s_axi.r_resp   = 0;

    hwif_out.ch_0_enable = ch_r[0].enable;
    hwif_out.ch_0_threshold = ch_r[0].threshold;
    hwif_out.ch_1_enable = ch_r[1].enable;
    hwif_out.ch_1_threshold = ch_r[1].threshold;
    hwif_out.ch_2_enable = ch_r[2].enable;
    hwif_out.ch_2_threshold = ch_r[2].threshold;
    hwif_out.ch_3_enable = ch_r[3].enable;
    hwif_out.ch_3_threshold = ch_r[3].threshold;
    hwif_out.irq_status_pending = irq_status_r.pending;
    hwif_out.irq_enable_mask = irq_enable_r.mask;
  end comb

end module Channelized
