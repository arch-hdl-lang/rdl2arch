use MyIpPkg;

bus AxiLite
  param ADDR_W: const = 3;
  param DATA_W: const = 32;

  aw_valid: out Bool;
  aw_ready: in  Bool;
  aw_addr:  out UInt<ADDR_W>;
  aw_prot:  out UInt<3>;

  w_valid:  out Bool;
  w_ready:  in  Bool;
  w_data:   out UInt<DATA_W>;
  w_strb:   out UInt<4>;

  b_valid:  in  Bool;
  b_ready:  out Bool;
  b_resp:   in  UInt<2>;

  ar_valid: out Bool;
  ar_ready: in  Bool;
  ar_addr:  out UInt<ADDR_W>;
  ar_prot:  out UInt<3>;

  r_valid:  in  Bool;
  r_ready:  out Bool;
  r_data:   in  UInt<DATA_W>;
  r_resp:   in  UInt<2>;
end bus AxiLite

module MyIp
  port clk:      in Clock<SysDomain>;
  port rst:      in Reset<Sync>;
  port s_axi: target AxiLite<ADDR_W=3, DATA_W=32>;
  port hwif_in:  in MyIpHwifIn;
  port hwif_out: out MyIpHwifOut;

  default seq on clk rising;

  reg ctrl_r: CtrlReg reset rst => CtrlReg { enable: 0, mode: 0 };
  reg status_r: StatusReg reset rst => StatusReg { status_code: 0 };

  reg bresp_valid_r: Bool reset rst => false;
  reg rresp_valid_r: Bool reset rst => false;
  reg rdata_r:       UInt<32> reset rst => 0;

  let wr_fire: Bool = s_axi.aw_valid and s_axi.w_valid and not bresp_valid_r;
  let rd_fire: Bool = s_axi.ar_valid and not rresp_valid_r;

  let rdata_mux: UInt<32> = match s_axi.ar_addr
    3'h0 => {27'h0, ctrl_r.mode, ctrl_r.enable},
    3'h4 => {24'h0, status_r.status_code},
    _ => 0
  end match;

  seq
    if bresp_valid_r and s_axi.b_ready
      bresp_valid_r <= false;
    end if
    if wr_fire
      bresp_valid_r <= true;
    end if
    if rresp_valid_r and s_axi.r_ready
      rresp_valid_r <= false;
    end if
    if rd_fire
      rresp_valid_r <= true;
    end if
    status_r.status_code <= hwif_in.status_status_code;
    if wr_fire
      if s_axi.aw_addr == 3'h0
        ctrl_r.enable <= s_axi.w_data[0];
        ctrl_r.mode <= s_axi.w_data[4:1];
      end if
    end if
    if rd_fire
      rdata_r <= rdata_mux;
    end if
  end seq

  comb
    s_axi.aw_ready = not bresp_valid_r;
    s_axi.w_ready  = not bresp_valid_r;
    s_axi.b_valid  = bresp_valid_r;
    s_axi.b_resp   = 0;

    s_axi.ar_ready = not rresp_valid_r;
    s_axi.r_valid  = rresp_valid_r;
    s_axi.r_data   = rdata_r;
    s_axi.r_resp   = 0;

    hwif_out.ctrl_enable = ctrl_r.enable;
    hwif_out.ctrl_mode = ctrl_r.mode;
  end comb

end module MyIp
