use InterruptsPkg;

bus AxiLite
  param ADDR_W: const = 4;
  param DATA_W: const = 32;

  aw_valid: out Bool;
  aw_ready: in  Bool;
  aw_addr:  out UInt<ADDR_W>;
  aw_prot:  out UInt<3>;

  w_valid:  out Bool;
  w_ready:  in  Bool;
  w_data:   out UInt<DATA_W>;
  w_strb:   out UInt<4>;

  b_valid:  in  Bool;
  b_ready:  out Bool;
  b_resp:   in  UInt<2>;

  ar_valid: out Bool;
  ar_ready: in  Bool;
  ar_addr:  out UInt<ADDR_W>;
  ar_prot:  out UInt<3>;

  r_valid:  in  Bool;
  r_ready:  out Bool;
  r_data:   in  UInt<DATA_W>;
  r_resp:   in  UInt<2>;
end bus AxiLite

module Interrupts
  port clk:      in Clock<SysDomain>;
  port rst:      in Reset<Sync>;
  port s_axi: target AxiLite<ADDR_W=4, DATA_W=32>;
  port hwif_in:  in InterruptsHwifIn;
  port hwif_out: out InterruptsHwifOut;
  port irq_status_intr:        out Bool;

  default seq on clk rising;

  reg irq_status_r: IrqStatusReg reset rst => IrqStatusReg { rx_done: 0, tx_done: 0, err: 0, live: 0 };
  reg irq_enable_r: IrqEnableReg reset rst => IrqEnableReg { rx_done_en: 0, tx_done_en: 0, err_mask: 0 };
  reg scratch_r: ScratchReg reset rst => ScratchReg { v: 0 };

  reg bresp_valid_r: Bool reset rst => false;
  reg rresp_valid_r: Bool reset rst => false;
  reg rdata_r:       UInt<32> reset rst => 0;

  let wr_fire: Bool = s_axi.aw_valid and s_axi.w_valid and not bresp_valid_r;
  let rd_fire: Bool = s_axi.ar_valid and not rresp_valid_r;

  let rdata_mux: UInt<32> = match s_axi.ar_addr
    4'h0 => {28'h0, irq_status_r.live, irq_status_r.err, irq_status_r.tx_done, irq_status_r.rx_done},
    4'h4 => {29'h0, irq_enable_r.err_mask, irq_enable_r.tx_done_en, irq_enable_r.rx_done_en},
    4'h8 => {24'h0, scratch_r.v},
    _ => 0
  end match;

  seq
    if bresp_valid_r and s_axi.b_ready
      bresp_valid_r <= false;
    end if
    if wr_fire
      bresp_valid_r <= true;
    end if
    if rresp_valid_r and s_axi.r_ready
      rresp_valid_r <= false;
    end if
    if rd_fire
      rresp_valid_r <= true;
    end if
    irq_status_r.rx_done <= irq_status_r.rx_done | hwif_in.irq_status_rx_done;
    irq_status_r.tx_done <= irq_status_r.tx_done | hwif_in.irq_status_tx_done;
    irq_status_r.err <= irq_status_r.err | hwif_in.irq_status_err;
    irq_status_r.live <= hwif_in.irq_status_live;
    if wr_fire
      if s_axi.aw_addr == 4'h0
        irq_status_r.rx_done <= irq_status_r.rx_done & (~s_axi.w_data[0]);
        irq_status_r.tx_done <= irq_status_r.tx_done & (~s_axi.w_data[1]);
        irq_status_r.err <= irq_status_r.err & (~s_axi.w_data[2]);
      end if
      if s_axi.aw_addr == 4'h4
        irq_enable_r.rx_done_en <= s_axi.w_data[0];
        irq_enable_r.tx_done_en <= s_axi.w_data[1];
        irq_enable_r.err_mask <= s_axi.w_data[2];
      end if
      if s_axi.aw_addr == 4'h8
        scratch_r.v <= s_axi.w_data[7:0];
      end if
    end if
    if rd_fire
      rdata_r <= rdata_mux;
    end if
  end seq

  comb
    s_axi.aw_ready = not bresp_valid_r;
    s_axi.w_ready  = not bresp_valid_r;
    s_axi.b_valid  = bresp_valid_r;
    s_axi.b_resp   = 0;

    s_axi.ar_ready = not rresp_valid_r;
    s_axi.r_valid  = rresp_valid_r;
    s_axi.r_data   = rdata_r;
    s_axi.r_resp   = 0;

    hwif_out.irq_enable_rx_done_en = irq_enable_r.rx_done_en;
    hwif_out.irq_enable_tx_done_en = irq_enable_r.tx_done_en;
    hwif_out.irq_enable_err_mask = irq_enable_r.err_mask;
    hwif_out.scratch_v = scratch_r.v;
    irq_status_intr = ((irq_status_r.rx_done & irq_enable_r.rx_done_en) != 1'h0) or ((irq_status_r.tx_done & irq_enable_r.tx_done_en) != 1'h0) or ((irq_status_r.err & (~irq_enable_r.err_mask)) != 1'h0) or (irq_status_r.live != 1'h0);
  end comb

end module Interrupts
