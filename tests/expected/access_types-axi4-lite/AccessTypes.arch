use AccessTypesPkg;

bus AxiLite
  param ADDR_W: const = 4;
  param DATA_W: const = 32;

  aw_valid: out Bool;
  aw_ready: in  Bool;
  aw_addr:  out UInt<ADDR_W>;
  aw_prot:  out UInt<3>;

  w_valid:  out Bool;
  w_ready:  in  Bool;
  w_data:   out UInt<DATA_W>;
  w_strb:   out UInt<4>;

  b_valid:  in  Bool;
  b_ready:  out Bool;
  b_resp:   in  UInt<2>;

  ar_valid: out Bool;
  ar_ready: in  Bool;
  ar_addr:  out UInt<ADDR_W>;
  ar_prot:  out UInt<3>;

  r_valid:  in  Bool;
  r_ready:  out Bool;
  r_data:   in  UInt<DATA_W>;
  r_resp:   in  UInt<2>;
end bus AxiLite

module AccessTypes
  port clk:      in Clock<SysDomain>;
  port rst:      in Reset<Sync>;
  port s_axi: target AxiLite<ADDR_W=4, DATA_W=32>;
  port hwif_in:  in AccessTypesHwifIn;
  port hwif_out: out AccessTypesHwifOut;

  default seq on clk rising;

  reg mixed_r: MixedReg reset rst => MixedReg { sw_rw_hw_r: 5, sw_rw_hw_rw: 0, sw_r_hw_w: 0, sw_w_hw_r: 0, w1c_field: 255 };
  reg writes_r: WritesReg reset rst => WritesReg { w1s_field: 0, w0c_field: 255, any_clr: 240, toggle_field: 0 };
  reg reads_r: ReadsReg reset rst => ReadsReg { rclr_field: 255, rset_field: 0 };

  reg bresp_valid_r: Bool reset rst => false;
  reg rresp_valid_r: Bool reset rst => false;
  reg rdata_r:       UInt<32> reset rst => 0;

  let wr_fire: Bool = s_axi.aw_valid and s_axi.w_valid and not bresp_valid_r;
  let rd_fire: Bool = s_axi.ar_valid and not rresp_valid_r;

  let rdata_mux: UInt<32> = match s_axi.ar_addr
    4'h0 => {mixed_r.w1c_field, 8'h0, mixed_r.sw_r_hw_w, mixed_r.sw_rw_hw_rw, mixed_r.sw_rw_hw_r},
    4'h4 => {writes_r.toggle_field, writes_r.any_clr, writes_r.w0c_field, writes_r.w1s_field},
    4'h8 => {16'h0, reads_r.rset_field, reads_r.rclr_field},
    _ => 0
  end match;

  seq
    if bresp_valid_r and s_axi.b_ready
      bresp_valid_r <= false;
    end if
    if wr_fire
      bresp_valid_r <= true;
    end if
    if rresp_valid_r and s_axi.r_ready
      rresp_valid_r <= false;
    end if
    if rd_fire
      rresp_valid_r <= true;
    end if
    mixed_r.sw_rw_hw_rw <= hwif_in.mixed_sw_rw_hw_rw;
    mixed_r.sw_r_hw_w <= hwif_in.mixed_sw_r_hw_w;
    if wr_fire
      if s_axi.aw_addr == 4'h0
        mixed_r.sw_rw_hw_r <= s_axi.w_data[3:0];
        mixed_r.sw_rw_hw_rw <= s_axi.w_data[7:4];
        mixed_r.sw_w_hw_r <= s_axi.w_data[23:16];
        mixed_r.w1c_field <= mixed_r.w1c_field & (~s_axi.w_data[31:24]);
      end if
      if s_axi.aw_addr == 4'h4
        writes_r.w1s_field <= writes_r.w1s_field | s_axi.w_data[7:0];
        writes_r.w0c_field <= writes_r.w0c_field & s_axi.w_data[15:8];
        writes_r.any_clr <= 8'h0;
        writes_r.toggle_field <= writes_r.toggle_field ^ s_axi.w_data[31:24];
      end if
      if s_axi.aw_addr == 4'h8
        reads_r.rclr_field <= s_axi.w_data[7:0];
        reads_r.rset_field <= s_axi.w_data[15:8];
      end if
    end if
    if rd_fire
      if s_axi.ar_addr == 4'h8
        reads_r.rclr_field <= 8'h0;
        reads_r.rset_field <= 8'hff;
      end if
    end if
    if rd_fire
      rdata_r <= rdata_mux;
    end if
  end seq

  comb
    s_axi.aw_ready = not bresp_valid_r;
    s_axi.w_ready  = not bresp_valid_r;
    s_axi.b_valid  = bresp_valid_r;
    s_axi.b_resp   = 0;

    s_axi.ar_ready = not rresp_valid_r;
    s_axi.r_valid  = rresp_valid_r;
    s_axi.r_data   = rdata_r;
    s_axi.r_resp   = 0;

    hwif_out.mixed_sw_rw_hw_r = mixed_r.sw_rw_hw_r;
    hwif_out.mixed_sw_rw_hw_rw = mixed_r.sw_rw_hw_rw;
    hwif_out.mixed_sw_w_hw_r = mixed_r.sw_w_hw_r;
    hwif_out.mixed_w1c_field = mixed_r.w1c_field;
    hwif_out.writes_w1s_field = writes_r.w1s_field;
    hwif_out.writes_w0c_field = writes_r.w0c_field;
    hwif_out.writes_any_clr = writes_r.any_clr;
    hwif_out.writes_toggle_field = writes_r.toggle_field;
    hwif_out.reads_rclr_field = reads_r.rclr_field;
    hwif_out.reads_rset_field = reads_r.rset_field;
  end comb

end module AccessTypes
